      <tr><td class="xn">Clean &amp; Jerk — build to heavy single</td><td>Warm-up + 1 single</td><td class="xl">~85% feel ≈ 242 lb</td><td class="xnote">RPE 8–8.5</td><td class="xnote">Full squat clean, full jerk. Same rule.</td></tr>
      <tr><td class="xn">C&amp;J — back-off sets</td><td>2 × 2</td><td class="xl">78% = 222 lb</td><td class="xnote">RPE 7</td><td class="xnote">2 back-offs</td></tr>
